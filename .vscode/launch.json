{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chess.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: Chess.Api",
      "program": "${workspaceFolder}/Chess.Api/bin/Debug/net10.0/Chess.Api.dll",
      "cwd": "${workspaceFolder}/Chess.Api",
      "stopAtEntry": false
    },
    {
      "name": "Launch frontend (npm run dev)",
      "type": "pwa-node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "Run Backend + Frontend",
      "configurations": ["Launch Chess.Api", "Launch frontend (npm run dev)"]
    }
  ]
}
