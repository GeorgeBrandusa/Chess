{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: Chess.Api",
      "type": "shell",
      "command": "dotnet build",
      "options": { "cwd": "${workspaceFolder}/Chess.Api" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run: Chess.Api",
      "type": "shell",
      "command": "dotnet run",
      "options": { "cwd": "${workspaceFolder}/Chess.Api" },
      "problemMatcher": []
    },
    {
      "label": "run: frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    }
  ]
}
